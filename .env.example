# =============================================================================
# PennyMac Trading Desktop Agent - Environment Configuration
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
#
# NOTE: No LLM API keys are needed. The reasoning agents run inside Cursor on
# your Cursor subscription; this config only covers the MCP server's data,
# Excel, and VBA tools. Keep comments on their OWN lines (python-dotenv treats
# inline comments after a value as part of the value).
# =============================================================================

# -----------------------------------------------------------------------------
# Snowflake (preferred data source)
# -----------------------------------------------------------------------------
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
# For SSO instead of password: SNOWFLAKE_AUTHENTICATOR=externalbrowser
SNOWFLAKE_AUTHENTICATOR=

# -----------------------------------------------------------------------------
# SQL Server (legacy; qrm_pulsar). Windows/integrated auth needs no password.
# -----------------------------------------------------------------------------
SQL_SERVER_HOST=
SQL_SERVER_PORT=
SQL_SERVER_DATABASE=
SQL_SERVER_TRUSTED_CONNECTION=true
SQL_SERVER_USER=
SQL_SERVER_PASSWORD=
SQL_SERVER_DRIVER=ODBC Driver 17 for SQL Server
SQL_SERVER_ENCRYPT=false
SQL_SERVER_TRUST_SERVER_CERTIFICATE=true

# -----------------------------------------------------------------------------
# Excel / VBA
# -----------------------------------------------------------------------------
EXCEL_MODELS_DIR=./models/workbooks
EXCEL_VISIBLE=false
VBA_SCRIPTS_DIR=./vba

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
ARTIFACTS_DIR=./artifacts
KNOWLEDGE_DIR=./knowledge

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
