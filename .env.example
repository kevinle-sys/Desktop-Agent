# =============================================================================
# PennyMac Trading Desktop Agent - Environment Configuration
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider Selection (CrewAI agents talk to providers via LiteLLM)
# Choose which provider powers the agents: "openai" or "anthropic"
# -----------------------------------------------------------------------------
LLM_PROVIDER=anthropic

# OpenAI (model name is used as-is, e.g. gpt-4o)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (the framework auto-prefixes to "anthropic/<model>" for LiteLLM)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-20250514

# Shared LLM settings
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0

# -----------------------------------------------------------------------------
# CrewAI behavior
# -----------------------------------------------------------------------------
# Optional: override the hierarchical-crew manager model (defaults to the
# active provider model above). Use the same naming as the provider expects.
MANAGER_MODEL=
# Print agent reasoning/tool steps to the console.
CREW_VERBOSE=true
# Max ReAct iterations per specialist before it must conclude.
AGENT_MAX_ITER=15

# -----------------------------------------------------------------------------
# Knowledge (RAG context for agents)
# Reference docs in ./knowledge are embedded so agents can retrieve them.
# Requires an embedding API key (OpenAI by default). Set ENABLE_KNOWLEDGE=false
# to turn RAG off (the list_documents/read_document tools still work).
# -----------------------------------------------------------------------------
ENABLE_KNOWLEDGE=true
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# Optional: dedicated embedding key. Falls back to OPENAI_API_KEY when blank.
EMBEDDING_API_KEY=

# -----------------------------------------------------------------------------
# Snowflake Connection (Secondary Market loan / pricing data)
# -----------------------------------------------------------------------------
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
# Use a password OR a private key path (key-pair auth recommended for prod).
SNOWFLAKE_PASSWORD=
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
# Optional: external browser SSO ("externalbrowser") instead of password.
SNOWFLAKE_AUTHENTICATOR=

# -----------------------------------------------------------------------------
# SQL Server (legacy source; the desk is migrating off this to Snowflake)
# -----------------------------------------------------------------------------
SQL_SERVER_HOST=
# Optional TCP port; leave blank to use the default/instance port.
SQL_SERVER_PORT=
SQL_SERVER_DATABASE=
# Auth: set SQL_SERVER_TRUSTED_CONNECTION=true for Windows/integrated auth,
# OR provide a SQL login user/password below.
SQL_SERVER_TRUSTED_CONNECTION=false
SQL_SERVER_USER=
SQL_SERVER_PASSWORD=
# Match an ODBC driver installed on this machine.
SQL_SERVER_DRIVER=ODBC Driver 17 for SQL Server
# TLS options (Driver 18 defaults to Encrypt=yes).
SQL_SERVER_ENCRYPT=true
SQL_SERVER_TRUST_SERVER_CERTIFICATE=false

# -----------------------------------------------------------------------------
# Excel Modeling
# Directory containing pricing-model workbooks referenced by models/registry.yaml
# -----------------------------------------------------------------------------
EXCEL_MODELS_DIR=./models/workbooks
# Set to "true" to keep Excel hidden when running via xlwings.
EXCEL_VISIBLE=false

# -----------------------------------------------------------------------------
# VBA / Process
# -----------------------------------------------------------------------------
VBA_SCRIPTS_DIR=./vba

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
